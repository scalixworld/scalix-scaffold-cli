{
  "name": "create-scalix",
  "version": "1.1.0",
  "description": "Create new Scalix applications from pre-built templates",
  "main": "cli/index.js",
  "bin": {
    "create-scalix": "./cli/index.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "rm -rf node_modules packages/*/node_modules cli/dist templates/*/node_modules",
    "dev": "npm run dev --workspace=@scalix-world/scaffold-cli",
    "publish-all": "npm run publish --workspaces"
  },
  "workspaces": [
    "cli",
    "packages/*"
  ],
  "keywords": [
    "scalix",
    "scaffold",
    "templates",
    "generator",
    "cli"
  ],
  "author": "Scalix <dev@scalix.world>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/scalixworld/scaffold-cli.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
