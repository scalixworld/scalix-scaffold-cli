{
  "name": "create-scalix",
  "version": "1.2.0",
  "description": "Create new Scalix applications from pre-built templates",
  "main": "dist/index.js",
  "bin": {
    "create-scalix": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scalix",
    "scaffold",
    "cli",
    "templates"
  ],
  "author": "Scalix World",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "chalk": "^5.0.0",
    "ora": "^7.0.0",
    "inquirer": "^9.0.0",
    "fs-extra": "^11.0.0",
    "path": "^0.12.7",
    "git-clone": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "rimraf": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
